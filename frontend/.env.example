# Variables d'environnement du frontend Next.js.
# Toutes sont NEXT_PUBLIC_* : elles sont intégrées au bundle client,
# donc PUBLIQUES — n'y mettre aucun secret.
#
# Dev : copier ce fichier en .env.local (ignoré par git).
# Prod (Vercel) : renseigner ces mêmes clés dans les variables
#                 d'environnement du projet Vercel.

# URL de l'API Django (backend).
# Dev  : http://localhost:8000
# Prod : https://<domaine-backend-cpanel-lws>
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL publique du site (front Vercel). Utilisée par le sitemap et le SEO.
# Dev  : http://localhost:3000
# Prod : https://<domaine-front-vercel>
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL du dépôt GitHub. Active les liens vers les artefacts sur la page Méthode.
# Laisser vide tant que le dépôt n'est pas poussé (les artefacts s'affichent
# alors en libellés, sans lien mort).
# Ex. : https://github.com/dmaiga/portfolio
NEXT_PUBLIC_REPO_URL=

# Secret de revalidation à la demande (ISR).
# ATTENTION : PAS de préfixe NEXT_PUBLIC — il reste côté serveur (route
# /api/revalidate uniquement), jamais intégré au bundle client.
# Doit être identique à REVALIDATE_SECRET côté Django.
REVALIDATE_SECRET=remplacer-par-un-secret-partage
