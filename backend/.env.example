SECRET_KEY=remplacer-par-une-cle-secrete
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Origines autorisées pour CORS (front). Prod : domaine Vercel.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base de données. Par défaut SQLite (aucune autre variable requise).
# PostgreSQL en réserve (ADR-004) : mettre DB_ENGINE=postgres + variables ci-dessous.
DB_ENGINE=sqlite
DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Revalidation à la demande du frontend Next.js (ISR).
# URL de la route Next ; vide => revalidation désactivée.
# Dev : http://localhost:3000/api/revalidate · Prod : https://<front>/api/revalidate
FRONTEND_REVALIDATE_URL=
# Secret partagé avec le frontend (doit être identique à REVALIDATE_SECRET côté Next).
REVALIDATE_SECRET=remplacer-par-un-secret-partage
